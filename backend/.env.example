# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=super-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# Supabase REST API client settings.
# These are different from DATABASE_URL and do not replace the SQLAlchemy database connection.
SUPABASE_URL=https://hbpaffqfpfzejlmocnrd.supabase.co
SUPABASE_KEY=your-supabase-publishable-or-service-key

# Database Configuration (MySQL)
# If DATABASE_URL is provided, it will take precedence. E.g., mysql+pymysql://user:pass@host:port/dbname
# If database settings are not configured, the app will fallback to SQLite for local development.
# Supabase example:
# DATABASE_URL=postgresql+psycopg://postgres:YOUR_DATABASE_PASSWORD@db.hbpaffqfpfzejlmocnrd.supabase.co:5432/postgres?sslmode=require
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=near_miss_db
